# ============================================================
# FlyPrint Cloud 环境变量配置模板（供 docker-compose 使用）
# 复制此文件为 .env 并放在本目录（与 docker-compose.yml 同目录）。不修改即可一键启动（默认端口 8012）。
# API 独立部署请使用 api/config.yaml，不使用本文件。
# ============================================================

# ===== 数据库配置 =====
POSTGRES_DB=fly_print_cloud
POSTGRES_USER=postgres
# 生产环境请使用强密码，生成方式: openssl rand -base64 32
POSTGRES_PASSWORD=your-secure-password-here
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# ===== API 服务配置 =====
API_PORT=8080

# ===== Admin Console 配置（仅在使用 docker-compose 构建时生效，admin/.env 会被忽略）=====
ADMIN_PORT=3000
# 前端 API/Auth 路径前缀（同域部署时通常与 Nginx 代理路径一致）
REACT_APP_API_BASE_PATH=/api/v1
REACT_APP_AUTH_BASE_PATH=/auth
# 旧版兼容：可写完整 URL，前端会只取 path 部分
# REACT_APP_API_URL=http://api:8080

# ===== 对外端口（仅 docker-compose 生效）=====
# Nginx 暴露的 HTTP 端口；下方 ALLOWED_ORIGINS、ADMIN_CONSOLE_URL、OAUTH2_REDIRECT_URI 需与此端口一致
HTTP_PORT=8012

# ===== 外部访问配置 =====
# 本地开发/测试：与 HTTP_PORT 一致；Edge 调用 API 时使用 EXTERNAL_API_URL
EXTERNAL_API_URL=http://localhost:8012
EXTERNAL_ADMIN_URL=http://localhost:8012

# 生产环境示例（使用实际域名）
# EXTERNAL_API_URL=https://print.example.com
# EXTERNAL_ADMIN_URL=https://print.example.com

# ===== 管理员账户配置 =====
# 首次启动时是否创建默认管理员
CREATE_DEFAULT_ADMIN=true
# 默认管理员密码（生产环境请立即修改）
DEFAULT_ADMIN_PASSWORD=admin123

# ===== OAuth2 模式选择 =====
# builtin: 内置认证服务（校园网/LAN 部署，无需 Keycloak）
# keycloak: 外部 Keycloak 认证（生产/公网部署）
OAUTH2_MODE=builtin

# ===== 内置模式 (builtin) 配置 =====
# JWT 签名密钥（生产环境必须替换）
# 生成方式: openssl rand -hex 32
OAUTH2_JWT_SIGNING_SECRET=change-this-to-a-random-secret
# Token 过期时间（秒）
OAUTH2_JWT_TOKEN_EXPIRY=3600
# JWT 签发者
OAUTH2_JWT_ISSUER=fly-print-cloud

# ===== Keycloak 模式配置（OAUTH2_MODE=keycloak 时使用）=====
# OAuth2 客户端配置
OAUTH2_CLIENT_ID=fly-print-admin-console
OAUTH2_CLIENT_SECRET=your-keycloak-client-secret

# OAuth2 端点（浏览器直接访问）
OAUTH2_AUTH_URL=http://localhost:8090/realms/fly-print/protocol/openid-connect/auth
OAUTH2_LOGOUT_URL=http://localhost:8090/realms/fly-print/protocol/openid-connect/logout

# OAuth2 端点（API 容器内访问）
OAUTH2_TOKEN_URL=http://host.docker.internal:8090/realms/fly-print/protocol/openid-connect/token
OAUTH2_USERINFO_URL=http://host.docker.internal:8090/realms/fly-print/protocol/openid-connect/userinfo

# JWKS 端点
OAUTH2_JWKS_URL=http://host.docker.internal:8090/realms/fly-print/protocol/openid-connect/certs

# JWT Issuer（必须与 Keycloak 实际签发的 issuer 一致）
OAUTH2_ISSUER=http://localhost:8090/realms/fly-print

# 登出重定向参数名
OAUTH2_LOGOUT_REDIRECT_URI_PARAM=post_logout_redirect_uri

# OAuth2 回调 URI（必须与 Keycloak 中注册的一致）；端口需与 HTTP_PORT 一致
OAUTH2_REDIRECT_URI=http://localhost:8012/auth/callback

# Admin Console URL（端口需与 HTTP_PORT 一致）
ADMIN_CONSOLE_URL=http://localhost:8012

# ===== CORS 配置 =====
# 允许的前端来源，多个用逗号分隔；端口需与 HTTP_PORT 一致
ALLOWED_ORIGINS=http://localhost:8012

# ===== Cookie 配置 =====
# HTTPS 环境必须为 true，本地 HTTP 设为 false
COOKIE_SECURE=false

# ===== 文件访问安全配置 =====
# 文件访问凭证签名密钥（生产环境必须设置为随机强密钥）
# 生成方式: openssl rand -hex 32
FILE_ACCESS_SECRET=change-this-to-a-random-secret
